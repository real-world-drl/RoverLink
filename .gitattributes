# Normalize line endings to LF in the repo and the working tree on every
# platform. These sources and scripts are consumed by Linux tooling (gcc,
# idf.py, bash, python) where a stray CR breaks shebangs (`python3\r`) and
# trips some parsers. Without this, core.autocrlf=true on Windows/WSL
# rewrites checkouts to CRLF and corrupts them.
* text=auto eol=lf

# Belt-and-suspenders for executable scripts.
*.sh text eol=lf
*.py text eol=lf
